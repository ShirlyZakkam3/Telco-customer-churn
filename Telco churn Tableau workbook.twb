      <aliases enabled='yes' />
      <column caption='Lifecycle Stages' datatype='string' name='[Calculation_1508424415657287682]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tenure] &lt;= 12 THEN &quot;New&quot;&#13;&#10;ELSEIF [tenure] &lt;= 36 THEN &quot;Growing&quot;&#13;&#10;ELSEIF [tenure] &lt;= 60 THEN &quot;Mature&quot;&#13;&#10;ELSE &quot;Loyal&quot;&#13;&#10;END' />
      </column>
      <column caption='Customer Stability Index' datatype='real' name='[Calculation_1508424415658864643]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[tenure] / [MonthlyCharges]' />
      </column>
      <column caption='Number of Services' datatype='integer' name='[Calculation_1508424415692554244]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT([OnlineSecurity] = &apos;Yes&apos;) +&#13;&#10;INT([OnlineBackup] = &apos;Yes&apos;) +&#13;&#10;INT([DeviceProtection] = &apos;Yes&apos;) +&#13;&#10;INT([TechSupport] = &apos;Yes&apos;) +&#13;&#10;INT([StreamingTV] = &apos;Yes&apos;) +&#13;&#10;INT([StreamingMovies] = &apos;Yes&apos;)' />
      </column>
      <column caption='Online Security (Yes)' datatype='integer' name='[Calculation_1508424415701245957]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [OnlineSecurity] = &apos;Yes&apos; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Online Backup (Yes)' datatype='integer' name='[Calculation_1508424415701454854]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [OnlineBackup] = &apos;Yes&apos; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Device Protestion (Yes)' datatype='integer' name='[Calculation_1508424415701602311]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [DeviceProtection] = &apos;Yes&apos; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Tech Support (Yes)' datatype='integer' name='[Calculation_1508424415701786632]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [TechSupport] = &apos;Yes&apos; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Streaming TV (Yes)' datatype='integer' name='[Calculation_1508424415701897225]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [StreamingTV] = &apos;Yes&apos; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Streaming Movies (Yes)' datatype='integer' name='[Calculation_1508424415702065162]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [StreamingMovies] = &apos;Yes&apos; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Churn Probablity' datatype='integer' name='[Calculation_1508424415710687243]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Churn] = &quot;Yes&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Digital Service Count' datatype='integer' name='[Calculation_1508424415736025101]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [OnlineSecurity] = &quot;Yes&quot; THEN 1 ELSE 0 END +&#13;&#10;IF [OnlineBackup] = &quot;Yes&quot; THEN 1 ELSE 0 END +&#13;&#10;IF [DeviceProtection] = &quot;Yes&quot; THEN 1 ELSE 0 END +&#13;&#10;IF [TechSupport] = &quot;Yes&quot; THEN 1 ELSE 0 END +&#13;&#10;IF [StreamingTV] = &quot;Yes&quot; THEN 1 ELSE 0 END +&#13;&#10;IF [StreamingMovies] = &quot;Yes&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Churn Rate' datatype='real' name='[Calculation_1612851631723253760]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT( IF [Churn] = &quot;Yes&quot; THEN 1 END ) / COUNT([customerID])' />
      </column>
      <column aggregation='None' datatype='integer' name='[Churn Probablity (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='-1' formula='[Calculation_1508424415710687243]' peg='0' size='0.303' />
      </column>
      <column datatype='string' name='[Churn]' role='dimension' type='nominal' />
      <column aggregation='None' caption='Customer Stability Index (bin)' datatype='integer' name='[Customer Stability Index (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='-1' formula='[Calculation_1508424415658864643]' peg='0' size='0.5' />
      </column>
      <column caption='Device Protection' datatype='string' name='[DeviceProtection]' role='dimension' type='nominal' />
      <column caption='Internet Service' datatype='string' name='[InternetService]' role='dimension' type='nominal' />
      <column aggregation='None' caption='Monthly Charges (bin)' datatype='integer' name='[Monthly Charges (bin)]' role='dimension' type='ordinal'>
